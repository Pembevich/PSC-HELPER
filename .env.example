DISCORD_TOKEN=

# Primary AI setup
GITHUB_MODELS_TOKEN=
GITHUB_MODELS_MODEL=openai/gpt-4.1
GITHUB_MODELS_ENDPOINT=https://models.github.ai/inference/chat/completions
GITHUB_MODELS_API_VERSION=2022-11-28

# Пул провайдеров (через запятую, индексы согласованы между KEYS/URLS/MODELS).
# 0.8: Gemini — приоритетный провайдер. Добавь Gemini-ключ через OpenAI-совместимый
# эндпоинт, чтобы P.OS использовал его в первую очередь, а остальные — только при
# его недоступности. URL с "googleapis.com" автоматически распознаётся как gemini.
# Пример:
#   POS_AI_PROVIDER_KEYS=<GEMINI_KEY>,<GITHUB_TOKEN>
#   POS_AI_PROVIDER_URLS=https://generativelanguage.googleapis.com/v1beta/openai/chat/completions,https://models.github.ai/inference/chat/completions
#   POS_AI_PROVIDER_MODELS=gemini-3.5-flash,openai/gpt-4.1
POS_AI_PROVIDER_KEYS=
POS_AI_PROVIDER_URLS=
POS_AI_PROVIDER_MODELS=

# Optional P.OS tuning
POS_AI_MAX_TOKENS=2048
POS_AI_TEMPERATURE=0.75
POS_AI_TOP_P=0.95
POS_AI_TIMEOUT_SECONDS=60
POS_AI_MAX_CONCURRENT_REQUESTS=2
POS_AI_RATE_LIMIT_FALLBACK_SECONDS=75

# Persistent SQLite backup. Keep this channel private and writable only by P.OS.
DB_BACKUP_CHANNEL_ID=

# Private Discord log area. Creation is only performed by an explicit Pumba command.
LOG_CATEGORY_ID=
LOG_CATEGORY_NAME=логи
PRIMARY_LOG_CHANNEL_ID=1392124917230731376

# Optional reputation services used by URL moderation.
VIRUSTOTAL_KEY=
GOOGLE_SAFEBROWSING_KEY=

# Модерация (0.8): дефолтные пороги флуда. Тонкая настройка — через P.OS на
# каждом сервере (update_settings). Маты/оскорбления разрешены и не модерируются.
FLOOD_WINDOW_SECONDS=7
FLOOD_MESSAGES_THRESHOLD=8

# Безопасность/антирейд (0.8). Пороги по умолчанию; на сервер настраиваются
# через P.OS. RAID_ACTION: alert | quarantine | kick | ban.
# quarantine (по умолчанию): свежий аккаунт мутится и теряет доступ, но остаётся
# на сервере — владелец потом снимает ограничения через P.OS (lift_restrictions).
RAID_JOIN_WINDOW_SECONDS=60
RAID_JOIN_THRESHOLD=8
RAID_MODE_COOLDOWN_SECONDS=600
MIN_ACCOUNT_AGE_HOURS=72
# Период сохранённой проверки Discord security posture: 120-3600 секунд.
SECURITY_MONITOR_INTERVAL_SECONDS=900
RAID_ACTION=quarantine
QUARANTINE_TIMEOUT_DAYS=28
MENTION_LIMIT=6
CROSSCHANNEL_WINDOW_SECONDS=15
CROSSCHANNEL_CHANNELS_THRESHOLD=3
